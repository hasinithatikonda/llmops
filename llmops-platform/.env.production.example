# Production Environment Variables

# Backend (Render)
DATABASE_URL=postgresql://user:password@host.render.com:5432/dbname
REDIS_URL=redis://host.render.com:6379
SECRET_KEY=production-secret-key-change-this
GROQ_API_KEY=gsk_your_production_groq_api_key
LANGSMITH_API_KEY=ls__your_langsmith_api_key
LANGSMITH_PROJECT=llmops-monitoring-prod
CHROMA_PERSIST_DIR=/opt/render/project/chroma_db
FRONTEND_URL=https://your-app.vercel.app
ENVIRONMENT=production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend (Vercel)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
